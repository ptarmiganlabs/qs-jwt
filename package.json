{
    "name": "qs-jwt",
    "version": "1.12.0",
    "description": "Command line tool for creating JWTs that can be used to authenticate with both Qlik Sense Cloud and client-managed Qlik Sense (a.k.a Qlik Sense Enterprise on Windows, QSEoW)",
    "main": "src/qs-jwt.js",
    "type": "module",
    "scripts": {
        "build:docker": "docker build -t qs-jwt:latest .",
        "qs-jwt": "node src/qs-jwt.js",
        "build:bundle": "esbuild src/qs-jwt.js --bundle --outfile=build.cjs --format=cjs --platform=node --target=node24 --inject:./src/lib/import-meta-url.js --define:import.meta.url=import_meta_url",
        "build:sea:prep": "node --experimental-sea-config src/sea-config.json",
        "build:binary:linux": "bash scripts/build-binary-linux.sh",
        "build:binary:macos": "bash scripts/build-binary-macos.sh",
        "build:binary:win": "powershell -ExecutionPolicy Bypass -File scripts/build-binary-win.ps1",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch",
        "format": "npm run format:prettier",
        "format:prettier": "npx prettier --config .prettierrc.yaml \"./**/*.{ts,css,less,js}\" --write",
        "lint": "npx eslint src/**/*.js",
        "lint:fix": "npx eslint --fix src/**/*.js",
        "pc": "pre-commit run --all-files",
        "security:audit": "npm audit --audit-level=high",
        "security:full": "npm run security:audit && snyk test --severity-threshold=high",
        "deps:audit": "audit-ci --high",
        "deps:lockfile": "lockfile-lint --path package-lock.json --validate-https --validate-integrity",
        "security:deps": "npm run deps:lockfile && npm run deps:audit",
        "license:check": "node scripts/check-licenses.js",
        "license:report": "license-checker-rseidelsohn --csv --out licenses.csv",
        "license:summary": "license-checker-rseidelsohn --summary",
        "license:json": "license-checker-rseidelsohn --json --out licenses.json",
        "license:full": "npm run license:summary && npm run license:check && npm run license:report",
        "knip": "knip"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ptarmiganlabs/qs-jwt.git"
    },
    "keywords": [
        "qlik-sense",
        "qliksense",
        "qlik",
        "senseops"
    ],
    "author": "Göran Sander",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/ptarmiganlabs/qs-jwt/issues"
    },
    "homepage": "https://github.com/ptarmiganlabs/qs-jwt#readme",
    "dependencies": {
        "commander": "^12.1.0",
        "jsonwebtoken": "^9.0.3",
        "node-forge": "^1.4.0",
        "uid-safe": "^2.1.5",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.8",
        "audit-ci": "^7.1.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-table": "^7.3.3",
        "eslint-plugin-jsdoc": "^63.0.2",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "knip": "^6.16.1",
        "license-checker-rseidelsohn": "^5.0.1",
        "lockfile-lint": "^5.0.0",
        "postject": "^1.0.0-alpha.6",
        "prettier": "^3.8.4",
        "snyk": "^1.1305.1",
        "vitest": "^4.1.8"
    }
}
